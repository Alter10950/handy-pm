# Supabase project settings — Project Settings > API in the Supabase dashboard.
# Safe to expose to the browser (public anon key, protected by Row Level Security).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret. Bypasses Row Level Security — server-only, never expose to the browser.
# Not required for local dev/auth in Phase 1; reserved for trusted backend
# operations in later phases.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret. Server-only — used by app/api/packing-slips/extract/route.ts to
# call the Anthropic Messages API and extract material line items from an
# uploaded packing slip. Also powers the field app's voice-note cleanup
# (app/api/field/voice-note/route.ts) and the estimate "explain" assistant
# (app/api/estimates/explain/route.ts). Never expose to the browser.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Secret. Server-only — used by lib/reports/send.ts to email daily/weekly
# project reports via Resend. Without a verified sending domain, Resend's
# sandbox sender (the default below) can only deliver to the Resend
# account's own verified email address — see docs/DECISIONS.md ADR-032.
RESEND_API_KEY=your-resend-api-key
# Optional. Overrides the sandbox default once a domain is verified —
# must be an address on that verified domain, e.g. "Handy PM <reports@yourdomain.com>".
RESEND_FROM_EMAIL=Handy PM <onboarding@resend.dev>

# Optional. Authenticates Vercel Cron's calls to app/api/cron/reports/* —
# Vercel automatically sends this as a Bearer token when the env var is
# set on the Vercel project. The route works without it (no-ops the
# check), so this can be added any time, not just before first deploy.
CRON_SECRET=a-long-random-string
